    {
      "type": "banner",
      "smallTitle": "15th Shaban Rites",
      "mainTitle": "15th Shaban Amaal and Duas",
      "details": "\"On the 15 night of Sha'aban, Allah(swt) takes decisions in the matters of sustenance, life and death and welfare of the people.\"- Holy Prophet(saws)",
      "subDetails": "Imam Mahdi Al Qaem - ajtfs was born at dawn in 255AH",
      "youtube": "https://www.youtube.com/embed/vo-fXY8tvUs?si=I7Ssov42mKyFic0p",
