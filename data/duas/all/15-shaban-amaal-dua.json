7 7-7 7\"></path></svg>\n</a>\n<a href=\"ziyarat-imam-mahdi-friday.html\" class=\"group flex items-center justify-between px-3 py-2 bg-slate-50 dark:bg-slate-800 rounded-lg hover:bg-emerald-50 dark:hover:bg-slate-700 transition-colors mb-2\">\n    <span class=\"font-medium text-slate-700 dark:text-emerald-400 group-hover:text-emerald-700 dark:group-hover:text-slate-200\">Ziyarat Imam Mahdi - Friday</span>\n    <svg class=\"w-4 h-4 text-slate-400 dark:text-emerald-400 group-hover:text-emerald-600 dark:group-hover:text-slate-500\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 5l7 7-7 7\"></path></svg>\n</a>",
