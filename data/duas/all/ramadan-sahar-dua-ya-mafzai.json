  "duas": [
    {
      "type": "dua",
      "id": "dua-1",
      "title": "Ya Mafzai - Dua e Sahar ",
      "description": "It is recommended to say the following supplication, which is considered the shortest supplications of the last hours of Ramadan nights (commencing the fast). Also known as dua-e-sahar and It is mentioned in the book of Iqbal al-A`mal:",
      "segments": [
        {
          "arabic": "يَا مَفْزَعِي عِنْدَ كُرْبَتِي",
          "transliteration": "ya mafza`i `inda kurbati",
          "translation": "O my Safe haven at grievances!"
        },
        {
          "arabic": "وَيَا غَوْثِي عِنْدَ شِدّتِي",
          "transliteration": "wa ya ghawthi `inda shiddati",
          "translation": "O my Aide at hardships!"
        },
        {
          "arabic": "إِلَيْكَ فَزِعْتُ",
          "transliteration": "ilayka fazi`tu",
          "translation": "To You do I turn,"
        },
        {
          "arabic": "وَبِكَ اسْتَغَثْتُ",
          "transliteration": "wa bika istaghathtu",
          "translation": "Your help do I seek,"
        },
        {
          "arabic": "وَبِكَ لُذْتُ",
          "transliteration": "wa bika ludhtu",
          "translation": "and with You do I take refuge."
        },
        {
          "arabic": "لاَ أَلُوذُ بِسِوَاكَ",
          "transliteration": "la aludhu bisiwaka",
          "translation": "I seek refuge with none save You"
        },
        {
          "arabic": "وَلاَ أَطْلُبُ ٱلْفَرَجَ إِلاَّ مِنْكَ",
          "transliteration": "wa la atlubu alfaraja illa minka",
          "translation": "and I beseech none for relief save You."
        },
        {
          "arabic": "فَأَغِثْنِي وَفَرِّجْ عَنِّي",
          "transliteration": "fa'aghithni wa farrij `anni",
          "translation": "So, (please) come to my help and free me from cares."
        },
        {
          "arabic": "يَا مَنْ يَقْبَلُ ٱلْيَسِيرَ",
          "transliteration": "ya man yaqbalu alyasira",
          "translation": "O He Who accepts even the least efforts"
        },
        {
          "arabic": "وَيَعْفُو عَنِ ٱلْكَثِيرِ",
          "transliteration": "wa ya`fu `an alkathiri",
          "translation": "excuses the much wrongdoing!"
        },
        {
          "arabic": "إِقْبَلْ مِنِّي ٱلْيَسِيرَ",
          "transliteration": "iqbal minni alyasira",
          "translation": "(Please do) accept my little effort"
        },
        {
          "arabic": "وَٱعْفُ عَنِّي ٱلْكَثِيرَ",
          "transliteration": "wa`fu `anni alkathira",
          "translation": "excuse my much wrongdoing."
        },
        {
          "arabic": "إِنِّكَ أَنْتَ ٱلْغَفُورُ ٱلرَّحِيمُ",
          "transliteration": "innaka anta alghafuru alrrahimu",
          "translation": "Verily, You are the Oft-forgiving, Merciful (Lord)."
        },
        {
          "arabic": "اللِّهُمِّ إِنِّي أَسْأَلُكَ إِيـمَاناً تُبَاشِرُ بِهِ قَلْبِي",
          "transliteration": "allahumma inni as'aluka imanan tubashiru bihi qalbi",
          "translation": "O Allah, I ask for faith with which You may fill my heart"
        },
        {
          "arabic": "وَيَقِيناً حَتَّىٰ أَعْلَمَ أَنِّهُ لَنْ يُصِيبَنِي إِلاَّ مَا كَتَبْتَ لِي",
          "transliteration": "wa yaqinan hatta a`lama annahu lan yusibani illa ma katabta li",
          "translation": "and for certitude so that I shall always know that nothing will afflict me save what You have ordained for me."
        },
        {
          "arabic": "وَرَضِّنِي مِنَ ٱلْعَيْشِ بِمَا قَسَمْتَ لِي",
          "transliteration": "wa raddini min al`ayshi bima qasamta li",
          "translation": "(Please) make me feel satisfied with the living that You decide for me."
        },
        {
          "arabic": "يَا أَرْحَمَ ٱلرَّاحِمِينَ",
          "transliteration": "ya arhama alrrahimina",
          "translation": "O most Merciful of all those who show mercy!"
        },
        {
          "arabic": "يَا عُدِّتِي فِي كُرْبَتِي",
          "transliteration": "ya `uddati fi kurbati",
          "translation": "O my means at times of agonies!"
        },
        {
          "arabic": "وَيَا صَاحِبِي فِي شِدِّتِي",
          "transliteration": "wa ya sahibi fi shiddati",
          "translation": "O my companion at times of hardships!"
        },
        {
          "arabic": "وَيَا وَلِيِّي فِي نِعْمَتِي",
          "transliteration": "wa ya waliyyi fi ni`mati",
          "translation": "O Source of my all bounties!"
        },
        {
          "arabic": "وَيَا غَايَتِي فِي رَغْبَتِي",
          "transliteration": "wa ya ghayati fi raghbati",
          "translation": "O my ultimate goal whenever I desire for something!"
        },
        {
          "arabic": "أَنْتَ ٱلسَّاتِرُ عَوْرَتِي",
          "transliteration": "anta alssatiru `awrati",
          "translation": "It is You Who is the concealer of my defects,"
        },
        {
          "arabic": "وَٱلآمِنُ رَوْعَتِي",
          "transliteration": "wal-aminu raw`ati",
          "translation": "Who secures me at times of horror,"
        },
        {
          "arabic": "وَٱلْمُقِيلُ عَثْرَتِي",
          "transliteration": "wal-muqilu `athrati",
          "translation": "and Who overlooks my slips."
        },
        {
          "arabic": "فَٱغْفِرْ لِي خَطِيئَتِي",
          "transliteration": "faghfir li khati'ati",
          "translation": "So, (please do) forgive my sin."
        },
        {
          "arabic": "يَا أَرْحَمَ ٱلرَّاحِمِينَ",
          "transliteration": "ya arhama alrrahimina",
          "translation": "O most Merciful of all those who show mercy!"
        }
      ],
